#!/bin/bash
# Pre-commit hook: Block AI attribution in commits
# This hook prevents commits that contain AI/Claude attribution

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Patterns to block (case-insensitive)
BLOCKED_PATTERNS=(
    "Claude"
    "Anthropic"
    "Co-Authored-By.*Claude"
    "Co-Authored-By.*Anthropic"
    "Co-Authored-By.*AI"
    "Generated by AI"
    "AI-generated"
    "GPT"
    "OpenAI"
    "ChatGPT"
)

# Check commit message
commit_msg_file=".git/COMMIT_EDITMSG"
if [ -f "$commit_msg_file" ]; then
    for pattern in "${BLOCKED_PATTERNS[@]}"; do
        if grep -iE "$pattern" "$commit_msg_file" > /dev/null 2>&1; then
            echo -e "${RED}ERROR: Commit message contains blocked pattern: $pattern${NC}"
            echo "AI attribution is not allowed in this repository."
            exit 1
        fi
    done
fi

# Files to skip (hook files contain the patterns by definition)
SKIP_FILES=(
    ".githooks/pre-commit"
    ".githooks/pre-push"
    ".githooks/README.md"
    "CLAUDE.md"
    "agent_context.json"
    "INSTRUCTIONS.md"
)

# Patterns to skip (directories or prefixes)
SKIP_PATTERNS=(
    ".claude/"
    "manuscript/"
)

# File extensions to skip (binary files that may contain false positives)
SKIP_EXTENSIONS="pdf|docx|png|jpg|jpeg|gif|sif|rds|RData"

# Check staged files for AI attribution comments
staged_files=$(git diff --cached --name-only --diff-filter=ACM)
if [ -n "$staged_files" ]; then
    for file in $staged_files; do
        # Skip hook files and Claude Code config
        skip=false
        for skip_file in "${SKIP_FILES[@]}"; do
            if [ "$file" = "$skip_file" ]; then
                skip=true
                break
            fi
        done
        for skip_pat in "${SKIP_PATTERNS[@]}"; do
            case "$file" in
                "$skip_pat"*) skip=true; break ;;
            esac
        done
        # Skip binary file extensions
        if echo "$file" | grep -qiE "\.($SKIP_EXTENSIONS)$"; then
            skip=true
        fi
        if [ "$skip" = true ]; then
            continue
        fi

        if [ -f "$file" ]; then
            for pattern in "${BLOCKED_PATTERNS[@]}"; do
                if grep -iE "$pattern" "$file" > /dev/null 2>&1; then
                    echo -e "${RED}ERROR: File '$file' contains blocked pattern: $pattern${NC}"
                    echo "AI attribution is not allowed in this repository."
                    exit 1
                fi
            done
        fi
    done
fi

echo -e "${GREEN}Pre-commit check passed.${NC}"

# Run pre-commit framework hooks (ruff, etc.)
if command -v pre-commit &> /dev/null; then
    pre-commit run --hook-stage pre-commit
    exit $?
fi

exit 0

{
  "project": "aealbo_autogeny",
  "description": "Full Spark HPC workflow for Aedes albopictus autogeny supplementary notebooks",
  "repo": "cosmelab/aealbo_autogeny",
  "github_url": "https://github.com/cosmelab/aealbo_autogeny",
  "pages_url": "https://cosmelab.github.io/aealbo_autogeny/",
  "container": "ghcr.io/cosmelab/aealbo_autogeny:latest",
  "singularity_image": "aealbo_autogeny_latest.sif",
  "workdir": "/workspace",

  "phases": [

    {
      "phase": 1,
      "title": "Setup: clone repo and pull container",
      "run_once": true,
      "steps": [
        {
          "id": "1a",
          "action": "clone_or_pull_repo",
          "commands": [
            "cd ~/projects",
            "if [ -d aealbo_autogeny ]; then cd aealbo_autogeny && git pull; else git clone https://github.com/cosmelab/aealbo_autogeny && cd aealbo_autogeny; fi"
          ],
          "verify": "git log --oneline -3"
        },
        {
          "id": "1b",
          "action": "pull_singularity_container",
          "commands": [
            "cd ~/projects/aealbo_autogeny",
            "singularity pull docker://ghcr.io/cosmelab/aealbo_autogeny:latest"
          ],
          "note": "Downloads ~4-6 GB SIF file. Only needed once — reuse across sessions.",
          "verify": "ls -lh aealbo_autogeny_latest.sif"
        }
      ]
    },

    {
      "phase": 2,
      "title": "Data: download from Zenodo or rsync from Dropbox",
      "run_once": true,
      "steps": [
        {
          "id": "2a",
          "action": "download_from_zenodo",
          "preferred": true,
          "commands": [
            "cd ~/projects/aealbo_autogeny",
            "bash scripts/00_download_data.sh"
          ],
          "note": "Update ZENODO_RECORD in scripts/00_download_data.sh before running. DOI: TBD.",
          "verify": "ls data/genotype_calls/*.vcf data/files/chip_ann.txt"
        },
        {
          "id": "2b",
          "action": "rsync_from_dropbox",
          "alternative": "use if Zenodo not yet published",
          "commands": [
            "rsync -avz --progress lcosme@dropbox.example.com:/path/to/autogeny_data/ ~/projects/aealbo_autogeny/data/"
          ],
          "note": "Contact PI for Dropbox credentials if Zenodo record is not yet live."
        },
        {
          "id": "2c",
          "action": "download_reference_genome",
          "optional": true,
          "note": "Only needed for File_S1 (QC step). ~1.9 GB.",
          "commands": [
            "mkdir -p ~/projects/aealbo_autogeny/data/genome",
            "wget -P ~/projects/aealbo_autogeny/data/genome/ https://ftp.ncbi.nlm.nih.gov/genomes/all/GCA/006/496/715/GCA_006496715.1_AalbF3/GCA_006496715.1_AalbF3_genomic.fna.gz",
            "mv ~/projects/aealbo_autogeny/data/genome/GCA_006496715.1_AalbF3_genomic.fna.gz ~/projects/aealbo_autogeny/data/genome/albo.fasta.gz"
          ],
          "verify": "ls -lh ~/projects/aealbo_autogeny/data/genome/albo.fasta.gz"
        }
      ]
    },

    {
      "phase": 3,
      "title": "BLOCKER: Fix File_S3 before rendering",
      "must_do_before": "rendering File_S3.pcadapt.Rmd",
      "steps": [
        {
          "id": "3a",
          "action": "disable_python_chunks_in_S3",
          "reason": "File_S3 contains Python chunks using matplotlib_venn which is NOT in the container. They must be set to eval=FALSE before rendering or the notebook will fail.",
          "file": "notebooks/File_S3.pcadapt.Rmd",
          "lines_to_edit": [335, 820, 1300],
          "change": "In each chunk header, change ```{python} to ```{python eval=FALSE}",
          "verify": "grep -n 'eval=FALSE' notebooks/File_S3.pcadapt.Rmd | wc -l  # should be >= 3"
        }
      ]
    },

    {
      "phase": 4,
      "title": "Render: all notebooks in dependency order",
      "render_command_template": "singularity exec --bind $PWD:/workspace --pwd /workspace aealbo_autogeny_latest.sif bash -c 'eval \"$(pixi shell-hook)\" && Rscript -e \"rmarkdown::render(\\\"notebooks/{notebook}\\\", output_dir=\\\"docs/html/\\\")\"'",
      "convenience": "bash scripts/render_notebooks.sh",
      "output_dir": "docs/html/",
      "steps": [
        {
          "id": "4-S1",
          "notebook": "File_S1.Quality_control.Rmd",
          "generates": "output/quality_control/file7.bed/bim/fam",
          "dependency": "none — run first",
          "estimated_time": "15-30 min"
        },
        {
          "id": "4-S2",
          "notebook": "File_S2_OutFlank.Rmd",
          "dependency": "file7.* from S1",
          "estimated_time": "30-60 min"
        },
        {
          "id": "4-S3",
          "notebook": "File_S3.pcadapt.Rmd",
          "dependency": "file7.* from S1",
          "blocker": "MUST apply phase 3 fix first",
          "estimated_time": "30-60 min"
        },
        {
          "id": "4-S4a",
          "notebook": "File_S4a.LDna_data_prep.Rmd",
          "dependency": "file7.* from S1",
          "generates": "output/ldna/ RDS files per chromosome",
          "estimated_time": "30-60 min"
        },
        {
          "id": "4-S4bcd",
          "notebooks": ["File_S4b.LDna_chr1.Rmd", "File_S4c.LDna_chr2.Rmd", "File_S4d.LDna_chr3.Rmd"],
          "dependency": "S4a output (RDS files per chromosome)",
          "parallel": true,
          "note": "S4b/c/d can run in parallel if multiple CPU cores available",
          "estimated_time": "1-2 hours each"
        },
        {
          "id": "4-S4e",
          "notebook": "File_S4e.LDna_combined.Rmd",
          "dependency": "S4b + S4c + S4d output",
          "estimated_time": "30 min"
        },
        {
          "id": "4-S4",
          "notebook": "File_S4.Linkage_network_analysis.Rmd",
          "dependency": "S4a + S4e output",
          "estimated_time": "~2 hours",
          "note": "Largest notebook — ~4000 lines. Submit as SLURM job if needed."
        },
        {
          "id": "snpeff",
          "action": "run_snpeff",
          "command": "bash scripts/cli/03_annotation/run_snpeff.sh",
          "dependency": "file7.* from S1",
          "generates": "SnpEff database + annotation VCF",
          "must_run_before": ["S5", "S6", "S7"],
          "estimated_time": "1-2 hours"
        },
        {
          "id": "4-S5",
          "notebook": "File_S5.Intersection_gene_expression_SNPs.Rmd",
          "dependency": "file7.* + SnpEff output"
        },
        {
          "id": "4-S6",
          "notebook": "File_S6.SNPs_functional_annotation.Rmd",
          "dependency": "SnpEff output"
        },
        {
          "id": "4-S7",
          "notebook": "File_S7.Frequencies.Rmd",
          "dependency": "file7.* + SnpEff output"
        },
        {
          "id": "4-S8",
          "notebook": "File_S8.Fst.Rmd",
          "dependency": "file7.* from S1"
        }
      ]
    },

    {
      "phase": 5,
      "title": "Deploy: push HTML to GitHub Pages",
      "steps": [
        {
          "id": "5a",
          "action": "verify_html_output",
          "commands": [
            "ls -lh ~/projects/aealbo_autogeny/docs/html/*.html"
          ],
          "verify": "should show 8+ HTML files"
        },
        {
          "id": "5b",
          "action": "commit_and_push_html",
          "commands": [
            "cd ~/projects/aealbo_autogeny",
            "git add docs/html/",
            "git commit -m 'Render supplementary notebooks'",
            "git push origin main"
          ]
        },
        {
          "id": "5c",
          "action": "enable_github_pages",
          "manual_step": true,
          "instructions": "On GitHub.com: cosmelab/aealbo_autogeny → Settings → Pages → Source: Deploy from branch → Branch: main → Folder: /docs → Save",
          "url_after": "https://cosmelab.github.io/aealbo_autogeny/"
        },
        {
          "id": "5d",
          "action": "verify_pages",
          "commands": [
            "curl -s -o /dev/null -w '%{http_code}' https://cosmelab.github.io/aealbo_autogeny/html/File_S1.Quality_control.html"
          ],
          "expected": "200"
        }
      ]
    },

    {
      "phase": 6,
      "title": "Data archive: upload to Zenodo",
      "run_once": true,
      "steps": [
        {
          "id": "6a",
          "action": "load_vault_credentials",
          "commands": [
            "eval $(python3 ~/projects/tracking-hub/scripts/05_load_vault.py --export)",
            "echo $ZENODO_UCR_API_KEY | cut -c1-8  # verify token loaded (shows first 8 chars)"
          ]
        },
        {
          "id": "6b",
          "action": "test_with_sandbox_first",
          "commands": [
            "cd ~/projects/aealbo_autogeny",
            "export ZENODO_SANDBOX=1",
            "bash scripts/01_upload_zenodo.sh"
          ],
          "note": "Sandbox requires a separate token from sandbox.zenodo.org — use for testing the script logic only"
        },
        {
          "id": "6c",
          "action": "upload_to_zenodo_production",
          "commands": [
            "cd ~/projects/aealbo_autogeny",
            "unset ZENODO_SANDBOX",
            "bash scripts/01_upload_zenodo.sh"
          ],
          "note": "Script pauses before publishing — review at zenodo.org/deposit/{id} first, then confirm with 'y'"
        },
        {
          "id": "6d",
          "action": "update_repo_with_doi",
          "after_publishing": true,
          "files_to_update": [
            "scripts/00_download_data.sh  → set ZENODO_RECORD to the numeric record ID",
            "README.md                    → replace [DOI: TBD] with real DOI",
            ".zenodo.json                 → add data DOI to related_identifiers"
          ],
          "commands": [
            "cd ~/projects/aealbo_autogeny",
            "git add scripts/00_download_data.sh README.md .zenodo.json",
            "git commit -m 'Add Zenodo data DOI'",
            "git push origin main"
          ]
        }
      ]
    }

  ],

  "git_rules": {
    "no_ai_attribution": true,
    "hook_installed": ".githooks/pre-commit — blocks AI attribution in commit messages",
    "commit_style": "short imperative: 'Render supplementary notebooks' not 'Added rendered notebook files'"
  },

  "contacts": {
    "repo_owner": "cosmelab (GitHub org)",
    "pi": "Peter Armbruster",
    "zenodo_token_location": "Supabase vault key: ZENODO_UCR_API_KEY"
  }
}

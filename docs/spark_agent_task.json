{
  "task": "render-all-notebooks-and-deploy-pages",
  "description": "Render all Aedes albopictus autogeny supplementary notebooks and deploy to GitHub Pages",
  "repo": "cosmelab/aealbopictus_autogeny",
  "container": "ghcr.io/cosmelab/aealbopictus_autogeny:latest",
  "runtime": "singularity",
  "singularity_image": "aealbopictus_autogeny_latest.sif",
  "workdir": "/workspace",
  "output_dir": "docs/html/",
  "pre_render_steps": [
    "git clone https://github.com/cosmelab/aealbopictus_autogeny && cd aealbopictus_autogeny",
    "singularity pull docker://ghcr.io/cosmelab/aealbopictus_autogeny:latest",
    "rsync data from Dropbox OR download from Zenodo [DOI: TBD]"
  ],
  "blockers": {
    "File_S3.pcadapt.Rmd": {
      "issue": "Python chunks use matplotlib_venn which is NOT in the container",
      "fix": "Set eval=FALSE on python chunk headers at lines 335, 820, and 1300 BEFORE rendering"
    }
  },
  "render_order": [
    {"notebook": "File_S1.Quality_control.Rmd", "generates": "output/quality_control/file7.*"},
    {"notebook": "File_S2_OutFlank.Rmd", "needs": "file7.*"},
    {"notebook": "File_S3.pcadapt.Rmd", "needs": "file7.*", "blocker": "fix eval=FALSE first"},
    {"notebook": "File_S4a.LDna_data_prep.Rmd", "needs": "file7.*"},
    {"notebook": "File_S4b.LDna_chr1.Rmd", "needs": "S4a output", "parallel_group": "chr"},
    {"notebook": "File_S4c.LDna_chr2.Rmd", "needs": "S4a output", "parallel_group": "chr"},
    {"notebook": "File_S4d.LDna_chr3.Rmd", "needs": "S4a output", "parallel_group": "chr"},
    {"notebook": "File_S4e.LDna_combined.Rmd", "needs": "S4b+S4c+S4d output"},
    {"notebook": "File_S4.Linkage_network_analysis.Rmd", "needs": "S4e output", "estimated_time": "~2 hours"},
    {"pre_step": "bash scripts/03_annotation/run_snpeff.sh", "generates": "SnpEff database + annotations"},
    {"notebook": "File_S5.Intersection_gene_expression_SNPs.Rmd", "needs": "file7.* + SnpEff output"},
    {"notebook": "File_S6.SNPs_functional_annotation.Rmd", "needs": "SnpEff output"},
    {"notebook": "File_S7.Frequencies.Rmd", "needs": "file7.* + SnpEff output"},
    {"notebook": "File_S8.Fst.Rmd", "needs": "file7.*"}
  ],
  "render_command": "singularity exec --bind $PWD:/workspace --pwd /workspace aealbopictus_autogeny_latest.sif Rscript -e \"rmarkdown::render('notebooks/{notebook}', output_dir='docs/html/')\"",
  "convenience_script": "bash scripts/render_notebooks.sh",
  "post_render_steps": [
    "git add docs/html/",
    "git commit -m 'Render all supplementary notebooks'",
    "git push origin main"
  ],
  "enable_github_pages": "Settings → Pages → Source: main branch, /docs folder → Save",
  "verification_url": "https://cosmelab.github.io/aealbopictus_autogeny/html/File_S1.Quality_control.html"
}
